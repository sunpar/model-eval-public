# Copy to .env for local development. Do not commit real provider keys.

# Local safety switch. Keep true unless you intentionally wire provider calls.
MODEL_EVAL_LOCAL_ONLY=true
MODEL_EVAL_ALLOWED_PROVIDERS=
MODEL_EVAL_DENIED_PROVIDERS=

# MVP provider credentials are local env vars only. Keep blank for dry runs.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Local SQLite default. Override with MODEL_EVAL_DATABASE_URL or DATABASE_URL for Postgres.
DATABASE_URL=sqlite+pysqlite:///./model_eval.sqlite3

# Set this when running a local Redis service for asynchronous worker jobs.
REDIS_URL=redis://localhost:6379/0

# Keep generated artifacts outside git-tracked source by default.
MODEL_EVAL_ARTIFACT_STORAGE_ROOT=~/.model-eval/artifacts
